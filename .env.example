# Path to GCP service-account JSON. Used by Google STT, TTS, and Vertex Gemini.
# Drop the file at data/credentials.json (the data/ directory is gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./data/credentials.json

# Project ID from your service account.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Vertex AI Gemini. us-east4 is the default; change if your project is elsewhere.
GOOGLE_CLOUD_LOCATION=us-east4

# Optional overrides — defaults are fine for Phase 0.
# UXFLOWS_LLM_MODEL=gemini-2.5-flash
# UXFLOWS_TTS_VOICE=en-US-Chirp3-HD-Charon
# UXFLOWS_HOST=127.0.0.1
# UXFLOWS_PORT=8000
